# Build artefacts kept out of commits but regenerated by `npm run build`.
# bin/librarian-codex-hook.js IS committed so users don't need npm install
# (see scripts/build-bundle.mjs). bin/PROVENANCE.json is NOT committed —
# every build embeds the current source SHA + built_at, which always drift
# by one commit (build runs before the commit that includes the build
# output), so committing it just produces noise. Regenerated locally and
# by CI.
node_modules/
*.log
.DS_Store
plugins/the-librarian/bin/PROVENANCE.json

# Autonomous build session notes — never committed
AUTONOMOUS-BUILD-NOTES-*.md

# Plugin runtime data (only ever exists at $PLUGIN_DATA on user machines)
state.json
log.jsonl

# pnpm cruft — this repo standardises on npm (committed package-lock.json).
# A stray pnpm run leaves these behind; they are not part of the project.
pnpm-lock.yaml
pnpm-workspace.yaml
