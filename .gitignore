# Build artefacts kept out of commits but regenerated by `npm run build`.
# bin/ IS committed so users don't need npm install; see scripts/build-bundle.mjs.
node_modules/
*.log
.DS_Store

# Autonomous build session notes — never committed
AUTONOMOUS-BUILD-NOTES-*.md

# Plugin runtime data (only ever exists at $PLUGIN_DATA on user machines)
state.json
log.jsonl
